{
  "name": "@openclaw/cdp-service",
  "version": "1.0.0",
  "description": "Standalone Chrome CDP service for OpenClaw with multi-agent isolation",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint src",
    "format": "oxfmt --write src"
  },
  "keywords": [
    "cdp",
    "chrome",
    "devtools-protocol",
    "browser-automation",
    "openclaw"
  ],
  "author": "OpenClaw Contributors",
  "license": "MIT",
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/exporter-zipkin": "^2.6.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "express": "^4.18.2",
    "prom-client": "^15.1.3",
    "tslog": "^4.9.0",
    "ws": "^8.13.0",
    "yaml": "^2.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.5",
    "tsx": "^3.12.7",
    "typescript": "^5.1.6"
  },
  "engines": {
    "node": ">=22.16.0"
  }
}
